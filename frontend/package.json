{
	"name": "podflow-frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"lint": "oxlint . && biome check .",
		"lint:fix": "oxlint --fix . && biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"check": "pnpm run format && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build"
	},
	"dependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^4.3.0",
		"@testing-library/jest-dom": "^6.6.0",
		"@testing-library/react": "^16.1.0",
		"@vitest/coverage-v8": "^3.0.0",
		"jsdom": "^25.0.0",
		"oxlint": "^0.12.0",
		"typescript": "^5.7.0",
		"vite": "^6.0.0",
		"vitest": "^3.0.0"
	},
	"engines": {
		"node": ">=22.0.0"
	}
}
